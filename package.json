{
  "name": "devpulse-vscode",
  "displayName": "DevPulse",
  "description": "Real-time developer activity tracking for DevPulse — sessions, projects, and productivity insights.",
  "version": "1.0.0",
  "publisher": "devpulse",
  "author": {
    "name": "DevPulse"
  },
  "categories": [
    "Visualization",
    "Education"
  ],
  "keywords": [
    "analytics",
    "code",
    "code time",
    "codetime",
    "flow",
    "focus",
    "metrics",
    "productivity",
    "devpulse",
    "dev-pulse",
    "time tracking",
    "tracking"
  ],
  "homepage": "https://dev-pulse-application.vercel.app",
  "license": "BSD-3-Clause",
  "icon": "images/devpulse-logo.png",
  "galleryBanner": {
    "color": "#AEC3D8",
    "theme": "light"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cipheroot/devpulse-vscode.git"
  },
  "engines": {
    "vscode": "^1.89.0"
  },
  "main": "./dist/extension",
  "browser": "./dist/web/extension",
  "scripts": {
    "vscode:prepublish": "webpack --mode production",
    "compile": "webpack --mode none",
    "compile:dev": "tsc -p ./",
    "watch": "webpack --mode none --watch",
    "open-in-browser": "vscode-test-web --open-devtools --quality insiders --extensionDevelopmentPath=. .",
    "test": "npm run compile:dev && node ./node_modules/vscode/bin/test"
  },
  "contributes": {
    "commands": [
      {
        "command": "devpulse.apikey",
        "title": "DevPulse: Api Key"
      },
      {
        "command": "devpulse.apiurl",
        "title": "DevPulse: Api Url"
      },
      {
        "command": "devpulse.proxy",
        "title": "DevPulse: Proxy"
      },
      {
        "command": "devpulse.debug",
        "title": "DevPulse: Debug"
      },
      {
        "command": "devpulse.disable",
        "title": "DevPulse: Enable/Disable Extension"
      },
      {
        "command": "devpulse.status_bar_enabled",
        "title": "DevPulse: Status Bar Enabled"
      },
      {
        "command": "devpulse.status_bar_coding_activity",
        "title": "DevPulse: Status Bar Coding Activity"
      },
      {
        "command": "devpulse.dashboard",
        "title": "DevPulse: Open Dashboard"
      },
      {
        "command": "devpulse.config_file",
        "title": "DevPulse: Open Config File..."
      },
      {
        "command": "devpulse.log_file",
        "title": "DevPulse: Open Log File..."
      }
    ],
    "configuration": {
      "title": "DevPulse",
      "properties": {
        "devpulse.apiKey": {
          "type": "string",
          "description": "Defaults to value from ~/.devpulse.cfg, unless running in browser.",
          "scope": "application"
        },
        "devpulse.apiUrl": {
          "type": "string",
          "description": "Defaults to https://dev-pulse-application.vercel.app/api/v1.",
          "scope": "application"
        },
        "devpulse.align": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "Defines the alignment of the status bar item, requires restart of VS Code"
        },
        "devpulse.alignPriority": {
          "type": "number",
          "default": 1,
          "description": "Defines priority of the status bar item. Higher values mean the item should be shown more to the left, requires restart of VS Code"
        }
      }
    }
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.1",
    "@types/request": "^2.48.13",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.89.0",
    "@types/webpack": "^5.28.5",
    "@types/which": "^3.0.4",
    "@vscode/test-web": "^0.0.74",
    "adm-zip": "0.5.16",
    "del-cli": "^7.0.0",
    "original-fs": "^1.2.0",
    "prettier": "3.6.2",
    "request": "2.88.2",
    "semver": "^7.7.3",
    "ts-loader": "^9.5.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "which": "^5.0.0"
  }
}
